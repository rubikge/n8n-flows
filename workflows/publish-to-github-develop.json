      "id": "n3",
      "name": "Get manifest.json",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1.1,
      "position": [
        480,
        0
      ],
      "webhookId": "737929a8-83fe-45c8-8b92-ab28ee1c3c56",
      "credentials": {
        "githubApi": {
          "name": "GitHub rubikge"
        }
