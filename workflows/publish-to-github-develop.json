    {
      "parameters": {
        "jsCode": "const listResp = $('List workflows on n8n-dev').first().json;\nconst workflows = listResp.data || [];\nif (listResp.nextCursor) {\n  throw new Error('n8n-dev has more than 250 workflows; add pagination to List workflows.');\n}\nconst idToName = Object.fromEntries(workflows.map(w => [w.id, w.name]));\n\nconst manifestRaw = $input.first().json;\nif (!manifestRaw || !manifestRaw.content) {\n  throw new Error('Could not read workflows/manifest.json from develop branch.');\n}\nconst manifest = JSON.parse(Buffer.from(manifestRaw.content, 'base64').toString('utf8'));\nconst manifestByName = new Map((manifest.workflows || []).map(e => [e.name, e]));\nconst usedFiles = new Set((manifest.workflows || []).map(e => e.file));\n\nfunction slugify(name) {\n  return name\n    .toLowerCase()\n    .normalize('NFKD').replace(/[̀-ͯ]/g, '')\n    .replace(/[^a-z0-9]+/g, '-')\n    .replace(/^-+|-+$/g, '')\n    .slice(0, 60) || 'workflow';\n}\n\nconst items = [];\nfor (const w of workflows) {\n  let entry = manifestByName.get(w.name);\n  if (!entry) {\n    const base = slugify(w.name);\n    let file = `${base}.json`;\n    let i = 2;\n    while (usedFiles.has(file)) {\n      file = `${base}-${i}.json`;\n      i++;\n    }\n    usedFiles.add(file);\n    entry = { file, name: w.name };\n  }\n  items.push({ json: { id: w.id, name: w.name, file: entry.file, idToName } });\n}\nreturn items;"
      },
      "id": "n4",
      "name": "Build work queue",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        0
      ]
    },
    {
      "parameters": {
        "url": "=http://localhost:5678/api/v1/workflows/{{ $json.id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-N8N-API-KEY",
              "value": "={{ $env.N8N_DEV_API_KEY }}"
            },
            {
              "name": "Accept",
              "value": "application/json"
            }
          ]
        },
        "options": {}
