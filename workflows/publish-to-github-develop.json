    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\n\nconst listResp = $('List workflows on n8n-dev').first().json;\nconst workflows = listResp.data || [];\n\nconst manifestRaw = $input.first().json;\nif (!manifestRaw || !manifestRaw.content) {\n  throw new Error('Could not read workflows/manifest.json from develop branch.');\n}\nconst manifestText = Buffer.from(manifestRaw.content, 'base64').toString('utf8');\nconst manifest = JSON.parse(manifestText);\nconst existingByName = new Map((manifest.workflows || []).map(e => [e.name, e]));\nconst usedFiles = new Set((manifest.workflows || []).map(e => e.file));\n\nfunction slugify(name) {\n  return name\n    .toLowerCase()\n    .normalize('NFKD').replace(/[̀-ͯ]/g, '')\n    .replace(/[^a-z0-9]+/g, '-')\n    .replace(/^-+|-+$/g, '')\n    .slice(0, 60) || 'workflow';\n}\n\nconst updated = manifest.workflows ? [...manifest.workflows] : [];\nfor (const w of workflows) {\n  if (existingByName.has(w.name)) continue;\n  const base = slugify(w.name);\n  let file = `${base}.json`;\n  let i = 2;\n  while (usedFiles.has(file)) {\n    file = `${base}-${i}.json`;\n    i++;\n  }\n  usedFiles.add(file);\n  updated.push({ file, name: w.name });\n}\n\nconst newText = JSON.stringify({ workflows: updated }, null, 2) + '\\n';\nconst oldHash = crypto.createHash('sha256').update(manifestText).digest('hex');\nconst newHash = crypto.createHash('sha256').update(newText).digest('hex');\n\nreturn { json: {\n  action: oldHash === newHash ? 'skip' : 'edit',\n  path: 'workflows/manifest.json',\n  file: 'manifest.json',\n  text: newText,\n  sha256: newHash,\n}};"
      },
