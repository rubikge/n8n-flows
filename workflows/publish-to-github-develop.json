    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const crypto = require('crypto');\n\nconst incoming = $('Normalize for repo').item.json;\nconst got = $json;\n\nlet existingSha256 = null;\nlet githubSha = null;\n\nif (got && got.content && got.encoding === 'base64') {\n  const existingText = Buffer.from(got.content, 'base64').toString('utf8');\n  existingSha256 = crypto.createHash('sha256').update(existingText).digest('hex');\n  githubSha = got.sha;\n}\n\nlet action;\nif (existingSha256 === null) action = 'create';\nelse if (existingSha256 === incoming.sha256) action = 'skip';\nelse action = 'edit';\n\nreturn { json: {\n  action,\n  path: incoming.path,\n  file: incoming.file,\n  text: incoming.text,\n  sha256: incoming.sha256,\n  githubSha,\n} };"
      },
