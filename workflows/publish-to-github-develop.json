      "id": "n5",
      "name": "Get full workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        960,
        0
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const crypto = require('crypto');\n\nconst wf = $json;\nconst queueItem = $('Build work queue').item.json;\nconst file = queueItem.file;\nconst idToName = queueItem.idToName;\n\nfunction stripNodeRuntime(node) {\n  const n = { ...node };\n  delete n.issues;\n  return n;\n}\n\nconst body = {\n  name: wf.name,\n  nodes: (wf.nodes || []).map(node => {\n    const n = stripNodeRuntime(node);\n    if (n.credentials) {\n      const rebound = {};\n      for (const [type, ref] of Object.entries(n.credentials)) {\n        rebound[type] = { name: ref.name };\n      }\n      n.credentials = rebound;\n    }\n    return n;\n  }),\n  connections: wf.connections || {},\n  settings: { ...(wf.settings || {}) },\n};\n\nif (body.settings.errorWorkflow) {\n  const errName = idToName && idToName[body.settings.errorWorkflow];\n  if (!errName) {\n    throw new Error(`Workflow \"${wf.name}\" references error workflow ${body.settings.errorWorkflow} that wasn't in the listing.`);\n  }\n  delete body.settings.errorWorkflow;\n  body.settings.errorWorkflowName = errName;\n}\n\nconst text = JSON.stringify(body, null, 2) + '\\n';\nconst contentBase64 = Buffer.from(text, 'utf8').toString('base64');\nconst sha256 = crypto.createHash('sha256').update(text).digest('hex');\nconst path = `workflows/${file}`;\n\nreturn { json: { path, file, text, contentBase64, sha256 } };"
      },
